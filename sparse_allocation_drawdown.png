005054106762479914,\n        \"min\": -0.0009023954389721628,\n        \"max\": 0.0010911006423982871,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          3.759630945635624e-05,\n          4.808221954954664e-05,\n          0.0001042910492505353\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"funding_ann\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.0068946497756306,\n        \"min\": -0.01592591006423983,\n        \"max\": 0.0,\n        \"num_unique_values\": 7,\n        \"samples\": [\n          -0.01592591006423983,\n          0.0,\n          -0.0021754814175985\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"cost_ann\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.001572704406634854,\n        \"min\": -0.005979443254817988,\n        \"max\": -0.0003854389721627409,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          -0.000986077428612374,\n          -0.0017559350602874577,\n          -0.0003854389721627409\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"total_ann\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.007511952188238394,\n        \"min\": -0.00589777374018559,\n        \"max\": 0.015254111137758763,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          -8.184795561227729e-05,\n          -0.0012469486374285508,\n          0.008201079057815844\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
