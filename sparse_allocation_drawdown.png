              "summary": "{\n  \"name\": \"strategy_mean_tests\",\n  \"rows\": 32,\n  \"fields\": [\n    {\n      \"column\": \"strategy\",\n      \"properties\": {\n        \"dtype\": \"string\",\n        \"num_unique_values\": 32,\n        \"samples\": [\n          \"R3_resid_carry_dv01_smooth_cost25bp\",\n          \"E_10Y_timing_cost25bp\",\n          \"R1_resid_top2_bottom2_cost5bp\"\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"ann_mean\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.0075925600202825915,\n        \"min\": -0.0038808512278597374,\n        \"max\": 0.021233554392576744,\n        \"num_unique_values\": 32,\n        \"samples\": [\n          -0.0015609640985308386,\n          0.013418866523911513,\n          3.66758636688099e-05\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"NW_t_mean\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 1.6872414068392627,\n        \"min\": -3.665359884536079,\n        \"max\": 2.670504630594665,\n        \"num_unique_values\": 32,\n        \"samples\": [\n          -2.0296203132708284,\n          1.545126263817407,\n          0.04540262664864434\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
