olumn\": \"MaxDD\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.09177384752544271,\n        \"min\": -0.32648862353384234,\n        \"max\": -0.02096760453461677,\n        \"num_unique_values\": 50,\n        \"samples\": [\n          -0.16335858569356043\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"hit_rate\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.07228127695906975,\n        \"min\": 0.23768736616702354,\n        \"max\": 0.5781584582441114,\n        \"num_unique_values\": 30,\n        \"samples\": [\n          0.3169164882226981\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"ann_turnover\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 1.521684135790973,\n        \"min\": 0.3854389721627409,\n        \"max\": 5.979443254817987,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          1.7559350602874577\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
