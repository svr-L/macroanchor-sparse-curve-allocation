3652,\n        \"min\": 0.08394291574141252,\n        \"max\": 0.2467498078102016,\n        \"num_unique_values\": 5,\n        \"samples\": [\n          0.08394291574141252,\n          0.2467498078102016,\n          0.14215888978435373\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": 10,\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.06031276244765041,\n        \"min\": 0.011359102827793005,\n        \"max\": 0.1730050625931825,\n        \"num_unique_values\": 5,\n        \"samples\": [\n          0.011359102827793005,\n          0.1730050625931825,\n          0.06738789417194303\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
