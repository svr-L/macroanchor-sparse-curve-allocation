n        \"std\": 0.007309197686256645,\n        \"min\": 0.00586445833333329,\n        \"max\": 0.024282999999999885,\n        \"num_unique_values\": 5,\n        \"samples\": [\n          0.011106113333333313,\n          0.024282999999999885,\n          0.014791638333333395\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": 10,\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.007038955620309741,\n        \"min\": 0.005351722222222368,\n        \"max\": 0.02088144444444439,\n        \"num_unique_values\": 5,\n        \"samples\": [\n          0.008545777777777817,\n          0.014841444444444341,\n          0.02088144444444439\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
