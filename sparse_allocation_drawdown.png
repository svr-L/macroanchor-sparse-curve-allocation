": 5.979443254817987,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.9860774286123741,\n          1.7559350602874577,\n          0.3854389721627409\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"alpha_vs_10Y_ann\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.0030845150352487804,\n        \"min\": 0.00025966503688328003,\n        \"max\": 0.011090088277118347,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.0006955830165970526,\n          0.00025966503688328003,\n          0.0045802975680392655\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beta_vs_10Y\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.18524492992012132,\n        \"min\": -0.26785854998720393,\n        \"max\": 0.3722736751103097,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.005813544152460246,\n          0.006946875161502788,\n          0.11162585716281588\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"R2_vs_10Y\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.22842873958792403,\n        \"min\": 0.01662349778136818,\n        \"max\": 0.610160843014226,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.01662349778136818,\n          0.019229087063859618,\n          0.33605859506232705\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"alpha_vs_EW_ann\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.0026003173432521697,\n        \"min\": 7.284302787221505e-06,\n        \"max\": 0.009150178825257912,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.0007240416403963575,\n          0.00029445416802956274,\n          0.0032045614740671734\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"beta_vs_EW\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.32041872968076623,\n        \"min\": -0.45836008539648704,\n        \"max\": 0.6230935363017391,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.007412745733010006,\n          0.008825640630666112,\n          0.22140826557813628\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"R2_vs_EW\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.2316920715238737,\n        \"min\": 0.008088760891348246,\n        \"max\": 0.534724669698994,\n        \"num_unique_values\": 12,\n        \"samples\": [\n          0.008088760891348246,\n          0.009288711774377512,\n          0.3956911934768923\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
